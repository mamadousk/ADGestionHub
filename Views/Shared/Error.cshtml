@model AdGestionHub.Models.ErrorViewModel
@{
    ViewData["Title"] = "Erreur";
}

<h1 class="text-danger">Erreur.</h1>
<h2 class="text-danger">Une erreur s'est produite lors du traitement de votre requête.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID de la requête :</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Mode Développement</h3>
<p>
    L'activation de l'environnement <strong>Développement</strong> affiche des informations détaillées sur l'erreur.
</p>
