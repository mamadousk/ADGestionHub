<!-- ==================== FILE: Views/Shared/_LoginPartial.cshtml ==================== -->
@using AdGestionHub.Models
@inject Microsoft.AspNetCore.Identity.SignInManager<ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-white fw-bold" asp-area="Identity" asp-page="/Account/Manage/Index" title="Mon Compte">
                @if (User.IsInRole("SuperAdmin"))
                {
                    <span class="badge bg-dark border border-warning text-warning me-1">BOSS</span>
                }
                else
                {
                    <span>👤</span>
                }
                @User.Identity?.Name
            </a>
        </li>
        <li class="nav-item">
            <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Welcome", "Home", new { area = "" })">
                <button id="logout" type="submit" class="nav-link btn btn-link text-white border-0 fw-bold">Déconnexion 🚪</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">S'inscrire</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">Connexion</a>
        </li>
    }
</ul>