@using Microsoft.AspNetCore.Http.Features
@{
    var consentFeature = Context.Features.Get<ITrackingConsentFeature>();
    var showBanner = !consentFeature?.CanTrack ?? false;
    var cookieString = consentFeature?.CreateConsentCookie();
}

@if (showBanner)
{
    <div id="cookieConsent" class="alert alert-info alert-dismissible fade show fixed-bottom mb-0 rounded-0 border-0 shadow-lg" style="background: #0f172a; color: #fff; z-index: 9999; padding: 1rem 0;">
        <div class="container d-flex flex-wrap align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="fas fa-cookie-bite fa-lg" style="color: #FF8C00;"></i>
                <span style="opacity: 0.9;">
                    Nous utilisons des cookies essentiels pour garantir le bon fonctionnement de notre plateforme.
                    <a asp-controller="Infos" asp-action="Cookies" class="text-warning text-decoration-underline" style="color: #FF8C00 !important;">En savoir plus</a>.
                </span>
            </div>
            <div class="d-flex gap-2 mt-2 mt-md-0">
                <button type="button" class="btn btn-sm btn-outline-light" data-bs-dismiss="alert" aria-label="Fermer" data-cookie-string="@cookieString">
                    <i class="fas fa-times me-1"></i> Refuser
                </button>
                <button type="button" class="btn btn-sm" style="background: #FF8C00; color: #fff; border: none;" data-bs-dismiss="alert" aria-label="Accepter" data-cookie-string="@cookieString">
                    <i class="fas fa-check me-1"></i> Accepter
                </button>
            </div>
        </div>
    </div>
    <script>
        (function () {
            var buttons = document.querySelectorAll("#cookieConsent button[data-cookie-string]");
            buttons.forEach(function (btn) {
                btn.addEventListener("click", function (el) {
                    document.cookie = el.target.dataset.cookieString;
                });
            });
        })();
    </script>
}