<!-- ==================== FILE: Views/Shared/_Layout.cshtml ==================== -->
@inject AdGestionHub.Data.ApplicationDbContext _context
@{
    AdGestionHub.Models.GlobalNotification activeNotification = null;
    try
    {
        activeNotification = _context.GlobalNotifications
            .FirstOrDefault(n => n.ExpiryDate > DateTime.Now && n.IsActive);
    }
    catch { /* Ignorer les erreurs de DB si la table n'existe pas encore */ }

    // Récupérer le contrôleur et l'action courants pour la navigation active
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AdGestionHub</title>

    <!-- Bootstrap & FontAwesome -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Notre CSS sur mesure (MODERN) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AdGestionHub.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- ===== BANDEAU D'ANNONCE GLOBAL ===== -->
        @inject AdGestionHub.Data.ApplicationDbContext _context
        @{
            AdGestionHub.Models.GlobalNotification activeNotification = null;
            try
            {
                activeNotification = _context.GlobalNotifications
                    .FirstOrDefault(n => n.ExpiryDate > DateTime.Now && n.IsActive);
            }
            catch { /* Ignorer les erreurs si la table n'existe pas */ }
        }

        @if (activeNotification != null)
        {
            <div id="globalAnnouncement" class="announcement-banner @(activeNotification.IsCritical ? "critical" : "info")" role="alert">
                <div class="container d-flex align-items-center justify-content-between py-2">
                    <div class="d-flex align-items-center gap-2">
                        <span class="announcement-icon">
                            <i class="fas @(activeNotification.IsCritical ? "fa-exclamation-triangle" : "fa-bullhorn")"></i>
                        </span>
                        <span class="announcement-text">@activeNotification.Message</span>
                        @if (activeNotification.ExpiryDate != null)
                        {
                            <span class="announcement-expiry badge bg-light text-dark ms-2">
                                <i class="far fa-clock me-1"></i> @activeNotification.ExpiryDate.ToString("HH:mm")
                            </span>
                        }
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Fermer" onclick="document.getElementById('globalAnnouncement').style.display='none'"></button>
                </div>
            </div>
            <style>
                        /* Ajustement du padding-top du body pour compenser la hauteur du bandeau */
                        body {
                            padding-top: 110px;
                        }

                        @@media (max-width: 768px) {
                            body {
                                padding-top: 130px;
                            }
                        }
            </style>
        }

        <!-- Navbar Moderne -->
        <nav class="navbar navbar-expand-lg navbar-main fixed-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="@(User.Identity.IsAuthenticated ? "Index" : "Welcome")">
                    Ad<span>GestionHub</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                   <ul class="navbar-nav me-auto mb-2 mb-lg-0">
    @if (User.Identity.IsAuthenticated)
    {
        @if (User.IsInRole("SuperAdmin"))
        {
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle fw-semibold" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                    <i class="fas fa-user-shield text-danger me-1"></i> Console Système
                </a>
                <ul class="dropdown-menu border-0 shadow-lg rounded-3 mt-2">
                    <li><a class="dropdown-item" asp-controller="SuperAdmin" asp-action="Index"><i class="fas fa-home me-2"></i>Vue d'ensemble</a></li>
                    <li><a class="dropdown-item text-danger" asp-controller="SuperAdmin" asp-action="Logs"><i class="fas fa-exclamation-circle me-2"></i>Journal des Erreurs</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" asp-controller="SuperAdmin" asp-action="ManageNotifications"><i class="fas fa-bullhorn me-2"></i>Notifications Globales</a></li>
                </ul>
            </li>
        }
        else
        {
            // Déclaration des classes dynamiques
            var isDashboard = ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index";
            var isProducts = ViewContext.RouteData.Values["controller"]?.ToString() == "Products";
            var isSales = ViewContext.RouteData.Values["controller"]?.ToString() == "Sales";
            var isDebts = ViewContext.RouteData.Values["controller"]?.ToString() == "Debts";
            var isUsers = ViewContext.RouteData.Values["controller"]?.ToString() == "Users";
            var isSettings = ViewContext.RouteData.Values["controller"]?.ToString() == "Settings";

            <li class="nav-item"><a class="nav-link @(isDashboard ? "active" : "")" asp-controller="Home" asp-action="Index"><i class="fas fa-chart-pie me-1"></i> Dashboard</a></li>
            <li class="nav-item"><a class="nav-link @(isProducts ? "active" : "")" asp-controller="Products" asp-action="Index"><i class="fas fa-box me-1"></i> Produits</a></li>
            <li class="nav-item"><a class="nav-link @(isSales ? "active" : "")" asp-controller="Sales" asp-action="Index"><i class="fas fa-coins me-1"></i> Ventes</a></li>
            
            @if (User.IsInRole("Admin"))
            {
                <li class="nav-item"><a class="nav-link @(isUsers ? "active" : "")" asp-controller="Users" asp-action="Index"><i class="fas fa-users me-1"></i> Employés</a></li>
                <li class="nav-item"><a class="nav-link @(isSettings ? "active" : "")" asp-controller="Settings" asp-action="Index"><i class="fas fa-sliders-h me-1"></i> Paramètres</a></li>
                <li class="nav-item"><a class="nav-link @(isDebts ? "active" : "")" asp-controller="Debts" asp-action="Index"><i class="fas fa-hand-holding-usd me-1"></i> Dettes</a></li>
            }
        }
    }
</ul>
          

                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <span class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem; font-weight: 600;">
                                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                                    </span>
                                    <span class="d-none d-lg-inline">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-3 mt-2">
                                    <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="fas fa-user-cog me-2"></i> Mon Profil</a></li>
                                    @if (!User.IsInRole("SuperAdmin"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Settings" asp-action="Index"><i class="fas fa-store me-2"></i> Ma Boutique</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt me-2"></i> Déconnexion</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a href="/Identity/Account/Login" class="btn btn-outline-orange btn-sm px-4">Connexion</a></li>
                            <li class="nav-item"><a href="/Identity/Account/Register" class="btn btn-orange btn-sm px-4">Essayer Gratuitement</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="pb-5">
        <!-- Container pour les messages de succès/erreur -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success border-0 shadow-sm rounded-4 d-flex align-items-center" role="alert">
                    <i class="fas fa-check-circle me-3 fa-lg"></i>
                    <div>@TempData["SuccessMessage"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger border-0 shadow-sm rounded-4 d-flex align-items-center" role="alert">
                    <i class="fas fa-exclamation-circle me-3 fa-lg"></i>
                    <div>@TempData["ErrorMessage"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        <div class="container py-3">
            @RenderBody()
        </div>
    </main>

    <partial name="_CookieConsentPartial" />
    <!-- ==================== SECTION FOOTER MODERNISÉ ==================== -->
    <footer class="footer-modern">
        <div class="container">
            <div class="row g-5">
                <!-- Colonne 1 : Marque et description -->
                <div class="col-lg-4">
                    <h5 class="text-white fw-bold mb-3" style="font-size: 1.5rem;">
                        Ad<span style="color: #FF8C00;">GestionHub</span>
                    </h5>
                    <p class="text-light" style="opacity: 0.9; line-height: 1.7;">
                        La solution SaaS de gestion intelligente pour les commerçants en RDC.
                        Simplifiez votre stock, suivez vos ventes et boostez votre boutique.
                    </p>
                    <div class="mt-3">
                        <span class="badge bg-dark border border-secondary px-3 py-2" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                            🚀 Adhil Digital
                        </span>
                    </div>
                </div>

                <!-- Colonne 2 : Liens légaux -->
                <div class="col-lg-4">
                    <h6 class="text-white fw-bold mb-3" style="font-size: 1rem; letter-spacing: 0.5px;">
                        <i class="fas fa-gavel me-2"></i> Informations légales
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <a asp-controller="Infos" asp-action="Confidentialite" class="text-light text-decoration-none" style="opacity: 0.85; transition: opacity 0.2s;">
                            <i class="fas fa-shield-alt me-2" style="width: 20px;"></i>Politique de confidentialité
                        </a>
                        <a asp-controller="Infos" asp-action="CGU" class="text-light text-decoration-none" style="opacity: 0.85; transition: opacity 0.2s;">
                            <i class="fas fa-file-contract me-2" style="width: 20px;"></i>Conditions générales d'utilisation (CGU)
                        </a>
                        <a asp-controller="Infos" asp-action="MentionsLegales" class="text-light text-decoration-none" style="opacity: 0.85; transition: opacity 0.2s;">
                            <i class="fas fa-balance-scale me-2" style="width: 20px;"></i>Mentions légales
                        </a>
                        <a asp-controller="Infos" asp-action="Cookies" class="text-light text-decoration-none" style="opacity: 0.85; transition: opacity 0.2s;">
                            <i class="fas fa-cookie-bite me-2" style="width: 20px;"></i>Gestion des cookies
                        </a>
                    </div>
                </div>

                <!-- Colonne 3 : Contact et réseaux sociaux -->
                <div class="col-lg-4">
                    <h6 class="text-white fw-bold mb-3" style="font-size: 1rem; letter-spacing: 0.5px;">
                        <i class="fas fa-address-card me-2"></i> Contact
                    </h6>
                    <p class="text-light mb-2" style="opacity: 0.9;">
                        <i class="fas fa-map-pin me-2" style="width: 20px;"></i> Limete 1ère Rue, Kinshasa, RDC
                    </p>
                    <p class="text-light mb-3" style="opacity: 0.9;">
                        <i class="fas fa-envelope me-2" style="width: 20px;"></i> contact@adhil-digital.com
                    </p>
                    <div class="d-flex gap-3 fs-5 mt-2">
                        <a href="#" class="text-light" style="opacity: 0.7; transition: opacity 0.2s;" title="Facebook">
                            <i class="fab fa-facebook"></i>
                        </a>
                        <a href="#" class="text-light" style="opacity: 0.7; transition: opacity 0.2s;" title="LinkedIn">
                            <i class="fab fa-linkedin"></i>
                        </a>
                        <a href="#" class="text-light" style="opacity: 0.7; transition: opacity 0.2s;" title="YouTube">
                            <i class="fab fa-youtube"></i>
                        </a>
                        <a href="#" class="text-light" style="opacity: 0.7; transition: opacity 0.2s;" title="WhatsApp">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Séparateur et copyright -->
            <hr class="border-secondary opacity-25 my-4" />
            <div class="text-center small text-light" style="opacity: 0.7;">
                &copy; @DateTime.Now.Year <strong>AdGestionHub</strong>. Un produit de
                <strong style="color: #FF8C00;">Adhil Digital</strong> – Tous droits réservés.
                <span class="badge border border-secondary ms-2" style="font-weight: 400;">Version bêta 1.0</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Modal Feedback (Global) -->
    <div class="modal fade" id="feedbackModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-content-modern">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold">Votre avis compte !</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-controller="Marketing" asp-action="SubmitFeedback" method="post">
                    <div class="modal-body px-4">
                        <div class="mb-3">
                            <label class="fw-semibold mb-2">Note</label>
                            <select name="note" class="form-select form-control-modern">
                                <option value="5">⭐⭐⭐⭐⭐ (Excellent)</option>
                                <option value="4">⭐⭐⭐⭐ (Très bien)</option>
                                <option value="3">⭐⭐⭐ (Moyen)</option>
                                <option value="2">⭐⭐ (Insuffisant)</option>
                                <option value="1">⭐ (Mauvais)</option>
                            </select>
                        </div>
                        <div>
                            <label class="fw-semibold mb-2">Commentaire</label>
                            <textarea name="commentaire" class="form-control form-control-modern" rows="3" placeholder="Partagez votre expérience..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pb-4 px-4">
                        <button type="submit" class="btn btn-primary-gradient w-100">Envoyer mon feedback</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>