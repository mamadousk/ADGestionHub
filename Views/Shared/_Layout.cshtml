@inject AdGestionHub.Data.ApplicationDbContext _context
@{
    // Sécurité : on essaie de récupérer la notification, si la table a un souci de colonne, le site ne plante pas.
    AdGestionHub.Models.GlobalNotification activeNotification = null;
    try
    {
        activeNotification = _context.GlobalNotifications
            .FirstOrDefault(n => n.ExpiryDate > DateTime.Now);
    }
    catch { /* Erreur SQL ignorée pour laisser le site fonctionner */ }
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AdGestionHub</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AdGestionHub.styles.css" asp-append-version="true" />

    <style>
        body {
            padding-top: 80px;
        }

        .text-orange {
            color: #FF8C00 !important;
        }

        .btn-orange {
            background-color: #FF8C00;
            color: white;
        }

            .btn-orange:hover {
                background-color: #e67e00;
                color: white;
            }

        .footer-adhilix {
            background-color: #1a1a1a;
            color: #fff;
        }

        .footer-links a {
            color: #aaa;
            text-decoration: none;
            font-size: 0.9rem;
        }

            .footer-links a:hover {
                color: #FF8C00;
            }
    </style>
</head>
<body>
    <header>
        @if (activeNotification != null)
        {
            <div class="alert @(activeNotification.IsCritical ? "alert-danger" : "alert-warning") text-center mb-0" style="border-radius:0; position: fixed; top: 0; width: 100%; z-index: 1050;">
                <i class="fas fa-bullhorn me-2"></i> @activeNotification.Message
            </div>
            <style>
                body {
                    padding-top: 130px;
                }</style>
        }

        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top" style="@(activeNotification != null ? "top: 48px;" : "")">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="@(User.Identity.IsAuthenticated ? "Index" : "Welcome")" style="color:#FF8C00; font-size:1.5rem;">
                    AdGestionHub
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle fw-bold text-danger" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fas fa-user-shield"></i> Console Système
                                    </a>
                                    <ul class="dropdown-menu border-0 shadow" aria-labelledby="adminDropdown">
                                        <li>
                                            <a class="dropdown-item" asp-controller="SuperAdmin" asp-action="Index">
                                                <i class="fas fa-home me-2"></i> Vue d'ensemble
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-danger" asp-controller="SuperAdmin" asp-action="Logs">
                                                <i class="fas fa-exclamation-circle me-2"></i> Journal des Erreurs
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="SuperAdmin" asp-action="ManageNotifications">
                                                <i class="fas fa-bullhorn me-2"></i> Notifications Globales
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold text-dark" asp-controller="Home" asp-action="Index">📊 Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold text-dark" asp-controller="Products" asp-action="Index">📦 Produits</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold text-dark" asp-controller="Sales" asp-action="Index">💰 Ventes</a>
                                </li>

                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold text-dark" asp-controller="Users" asp-action="Index">👥 Employés</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold text-dark" asp-controller="Settings" asp-action="Index">⚙️ Profil</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link fw-semibold text-dark" asp-controller="Debts" asp-action="Index">📓 Dettes</a>
                                    </li>
                                    <li class="nav-item ms-lg-2">
                                        <button type="button" class="btn btn-sm btn-outline-warning rounded-pill mt-1" data-bs-toggle="modal" data-bs-target="#feedbackModal">
                                            ⭐ Avis
                                        </button>
                                    </li>
                                }
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-3">
                                <span class="fw-semibold text-muted small">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="form-inline">
                                    <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3">Déconnexion</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a href="/Identity/Account/Login" class="btn btn-sm btn-orange rounded-pill px-3 me-2">Connexion</a>
                            </li>
                            <li class="nav-item">
                                <a href="/Identity/Account/Register" class="btn btn-sm btn-outline-warning rounded-pill px-3" style="color:#FF8C00; border-color:#FF8C00;">S’inscrire</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mt-3" role="alert" style="border-left: 5px solid #28a745 !important;">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-adhilix mt-auto">
        <div class="container py-4">
            <div class="row gx-5">
                <div class="col-lg-4 mb-4">
                    <h5 class="text-orange fw-bold">AdGestionHub</h5>
                    <p class="text-muted small">La solution SaaS de gestion intelligente pour les commerçants en RDC. Simplifiez votre stock et boostez votre boutique.</p>
                    <span class="badge bg-dark">🚀 Adhilix Group</span>
                </div>
                <div class="col-lg-4 mb-4">
                    <h5 class="text-white fw-bold">Informations</h5>
                    <div class="footer-links">
                        <div class="mb-2"><a asp-controller="Infos" asp-action="Confidentialite">Politique de Confidentialité</a></div>
                        <div class="mb-2"><a asp-controller="Infos" asp-action="CGU">Conditions Générales (CGU)</a></div>
                        <div class="mb-2"><a asp-controller="Infos" asp-action="MentionsLegales">Mentions Légales</a></div>
                    </div>
                </div>
                <div class="col-lg-4 mb-4">
                    <h5 class="text-white fw-bold">Contact</h5>
                    <p class="text-muted small mb-1">📍 Limete 1ère Rue, Kinshasa, RDC</p>
                    <p class="text-muted small">📧 contact@adhilix.com</p>
                </div>
            </div>
            <hr class="border-secondary my-3">
            <div class="text-center small text-muted">
                &copy; 2026 <strong>AdGestionHub.</strong> Un produit de Adhil Digital Solutions <span class="badge border border-secondary ms-2">Version bêta</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <div class="modal fade" id="feedbackModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header" style="background-color: #FF8C00; color: white;">
                    <h5 class="modal-title">Votre avis sur AdGestionHub</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-controller="Marketing" asp-action="SubmitFeedback" method="post">
                    <div class="modal-body">
                        <label class="fw-bold">Note :</label>
                        <select name="note" class="form-select mb-3">
                            <option value="5">⭐⭐⭐⭐⭐ (Excellent)</option>
                            <option value="4">⭐⭐⭐⭐ (Très bien)</option>
                            <option value="3">⭐⭐⭐ (Moyen)</option>
                            <option value="2">⭐⭐ (Insuffisant)</option>
                            <option value="1">⭐ (Mauvais)</option>
                        </select>
                        <label class="fw-bold">Commentaire :</label>
                        <textarea name="commentaire" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="submit" class="btn btn-warning text-white w-100 rounded-pill fw-bold">Envoyer mon feedback</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>