<!-- ==================== FILE: Views/Expenses/Index.cshtml ==================== -->
@using AdGestionHub.Models
@model IEnumerable<Expense>

@{
    ViewData["Title"] = "Journal des Dépenses";
    var total = Model.Sum(e => e.Amount);
    var categories = Model.GroupBy(e => e.Category).Select(g => new { Nom = g.Key, Total = g.Sum(e => e.Amount) }).OrderByDescending(g => g.Total);
}

<div>
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-0"><i class="fas fa-wallet text-primary me-2"></i>Journal des Dépenses</h1>
            <p class="text-muted">Suivez vos charges et optimisez votre rentabilité.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary-gradient">
            <i class="fas fa-plus me-2"></i>Nouvelle Dépense
        </a>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="card-dashboard" style="border-left: 4px solid #ef4444;">
                <div class="stat-label">Total des dépenses</div>
                <div class="stat-number text-danger">@total.ToString("N2") $</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Tableau -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-modern mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Description</th>
                                    <th>Catégorie</th>
                                    <th class="text-end">Montant</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderByDescending(e => e.Date))
                                {
                                    <tr>
                                        <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                        <td>@item.Description</td>
                                        <td><span class="badge-status info">@item.Category</span></td>
                                        <td class="text-end fw-bold text-danger">- @item.Amount.ToString("N2") $</td>
                                        <td class="text-center">
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Supprimer cette dépense ?');">
                                                <button type="submit" class="btn btn-sm btn-soft text-danger">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Résumé par catégorie -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0"><i class="fas fa-chart-pie me-2"></i>Répartition par catégorie</h5>
                </div>
                <div class="card-body p-3">
                    <div class="list-group list-group-flush">
                        @foreach (var cat in categories)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-2">
                                <span>@cat.Nom</span>
                                <span class="fw-bold text-danger">@cat.Total.ToString("N2") $</span>
                            </div>
                        }
                        <div class="list-group-item d-flex justify-content-between align-items-center border-top pt-3 mt-2 fw-bold">
                            <span>TOTAL</span>
                            <span class="text-danger h5 mb-0">@total.ToString("N2") $</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>