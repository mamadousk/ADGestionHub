@using AdGestionHub.Models
@model IEnumerable<ApplicationUser>
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: #FF8C00;">👥 Gestion des Employés</h2>
        <a asp-action="Create" class="btn text-white" style="background-color: #FF8C00;">+ Ajouter un employé</a>
    </div>

    <table class="table table-hover shadow-sm bg-white">
        <thead style="background-color: #fff3e0;">
            <tr>
                <th>Email / Nom d'utilisateur</th>
                <th>Rôles</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>
                        @{
                            // On utilise maintenant ApplicationUser pour récupérer les rôles
                            var roles = await UserManager.GetRolesAsync(user);
                            if (roles.Any())
                            {
                                foreach (var role in roles)
                                {
                                    <span class="badge @(role == "Admin" ? "bg-danger" : "bg-info")">@role</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Aucun rôle</span>
                            }
                        }
                    </td>
                    <td>
                        @if (user.Email != User.Identity?.Name)
                        {
                            <button class="btn btn-sm btn-outline-danger">Désactiver</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>