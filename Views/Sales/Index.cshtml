@model IEnumerable<AdGestionHub.Models.Sale>

<div class="container mt-5">
    <h2 class="mb-4" style="color: #FF8C00;">📊 Liste des Ventes</h2>

    <table class="table table-hover table-bordered shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th>Produits (Panier)</th>
                <th class="text-center">Total Articles</th>
                <th class="text-center">Prix Final ($)</th>
                <th>Client</th>
                <th>Mode de Paiement</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var vente in Model)
            {
                <tr>
                    <td>
                        @if (vente.Items != null && vente.Items.Any())
                        {
                            @string.Join(", ", vente.Items.Select(i => i.ProductName))
                        }
                        else
                        {
                            <span class="text-muted italic">Aucun article</span>
                        }
                    </td>
                    <td class="text-center">@vente.Items?.Sum(i => i.Quantity)</td>
                    <td class="text-center fw-bold">@vente.FinalPrice.ToString("N2") $</td>
                    <td>@(vente.CustomerName ?? "Client Anonyme")</td>
                    <td>@vente.PaymentMethod</td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            @* Bouton Télécharger la facture *@
                            <a asp-action="DownloadReceipt" asp-route-id="@vente.Id" class="btn btn-sm btn-outline-dark" title="Télécharger la facture">
                                <i class="fas fa-file-download me-1"></i> Facture PDF
                            </a>

                            @* Bouton Détails *@
                            <a asp-action="Details" asp-route-id="@vente.Id" class="btn btn-sm btn-info text-white">
                                <i class="fas fa-eye"></i> Détails
                            </a>

                            @* Bouton déclencheur Modal Supprimer *@
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@vente.Id">
                                <i class="fas fa-trash"></i>
                            </button>

                            @* Modal de Confirmation *@
                            <div class="modal fade" id="deleteModal-@vente.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 shadow">
                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title">⚠️ Confirmation</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body text-center p-4">
                                            <i class="fas fa-exclamation-triangle text-danger mb-3" style="font-size: 3rem;"></i>
                                            <p class="mb-0">Supprimer la vente de <strong>@(vente.CustomerName ?? "ce client")</strong> ?</p>
                                            <small class="text-muted">Cette action remettra les articles en stock.</small>
                                        </div>
                                        <div class="modal-footer bg-light d-flex justify-content-between">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                            <form asp-action="Delete" asp-route-id="@vente.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger px-4">Confirmer</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a asp-action="Create" class="btn text-white fw-bold shadow-sm" style="background-color: #FF8C00;">➕ Enregistrer une Nouvelle Vente</a>
    </div>
</div>