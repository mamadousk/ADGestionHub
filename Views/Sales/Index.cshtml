<!-- ==================== FILE: Views/Sales/Index.cshtml ==================== -->
@model IEnumerable<AdGestionHub.Models.Sale>

<div>
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-0">💰 Historique des Ventes</h1>
            <p class="text-muted">Toutes vos transactions enregistrées</p>
        </div>
        <a asp-action="Create" class="btn btn-primary-gradient">
            <i class="fas fa-plus me-2"></i> Enregistrer une Vente
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th>Produits</th>
                            <th class="text-center">Qté Totale</th>
                            <th class="text-end">Total</th>
                            <th>Client</th>
                            <th>Paiement</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vente in Model)
                        {
                            <tr>
                                <td>
                                    @if (vente.Items != null && vente.Items.Any())
                                    {
                                        @string.Join(", ", vente.Items.Select(i => i.ProductName))
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Aucun article</span>
                                    }
                                </td>
                                <td class="text-center">@vente.Items?.Sum(i => i.Quantity)</td>
                                <td class="text-end fw-bold text-success">@vente.FinalPrice.ToString("N2") $</td>
                                <td>@(vente.CustomerName ?? "Anonyme")</td>
                                <td><span class="badge-status info">@vente.PaymentMethod</span></td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="DownloadReceipt" asp-route-id="@vente.Id" class="btn btn-sm btn-soft" title="Facture PDF">
                                            <i class="fas fa-file-pdf"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@vente.Id" class="btn btn-sm btn-soft" title="Détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-soft text-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@vente.Id" title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>

                                    <!-- Modal de suppression -->
                                    <div class="modal fade" id="deleteModal-@vente.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content modal-content-modern">
                                                <div class="modal-header border-0 pt-4">
                                                    <h5 class="modal-title fw-bold text-danger"><i class="fas fa-exclamation-triangle me-2"></i> Confirmation</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body text-center py-4">
                                                    <p class="mb-0">Supprimer la vente de <strong>@(vente.CustomerName ?? "ce client")</strong> ?</p>
                                                    <small class="text-muted">Cette action remettra les articles en stock.</small>
                                                </div>
                                                <div class="modal-footer border-0 pb-4 d-flex justify-content-between">
                                                    <button type="button" class="btn btn-soft" data-bs-dismiss="modal">Annuler</button>
                                                    <form asp-action="Delete" asp-route-id="@vente.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-danger px-4">Confirmer</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>