@model AdGestionHub.Models.Sale
@inject AdGestionHub.Data.ApplicationDbContext _context

@{
    Layout = null;
    var settings = _context.StoreSettings.FirstOrDefault(s => s.BoutiqueId == Model.BoutiqueId)
                   ?? new AdGestionHub.Models.StoreSettings { StoreName = "Mon Enseigne" };
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            color: #333;
        }

        .orange-bar {
            background-color: #FF8C00;
            height: 10px;
            border-radius: 5px;
        }

        .invoice-title {
            color: #FF8C00;
            font-weight: 800;
            font-size: 38px;
        }

        .store-name-title {
            font-size: 2.5rem;
            font-weight: 900;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .store-info-box {
            font-size: 1.3rem;
        }

        .total-box {
            background-color: #fff3e0;
            padding: 20px;
            border-left: 6px solid #FF8C00;
            text-align: right;
        }

        .receipt-number {
            font-size: 1.6rem;
            font-weight: bold;
            color: #444;
        }
    </style>
</head>
<body class="p-5">
    <div class="orange-bar mb-4"></div>

    <div class="row">
        <div class="col-6">
            <h1 class="invoice-title">REÇU DE VENTE</h1>
            @* Affiche le numéro calculé par le controller *@
            <p class="receipt-number">N° : #@ViewBag.StoreInvoiceNumber</p>

            <div class="mt-4">
                <p class="mb-0 text-muted small fw-bold">FACTURÉ À :</p>
                <h5 class="fw-bold">@(string.IsNullOrEmpty(Model.CustomerName) ? "Client au comptoir" : Model.CustomerName)</h5>
            </div>
        </div>

        <div class="col-6 text-end">
            <div class="store-info-box">
                <div class="store-name-title">@settings.StoreName</div>
                <p>
                    @if (!string.IsNullOrEmpty(settings.Address))
                    {
                        <span>@settings.Address</span>
                    
                        <br>
                    }
                    @if (!string.IsNullOrEmpty(settings.PhoneNumber))
                    {
                        <span class="fw-bold">@settings.PhoneNumber</span>
                    }
                    @* L'adresse mail a été supprimée ici *@
                </p>
            </div>
        </div>
    </div>

    <div class="my-5">
        <table class="table table-bordered">
            <thead class="table-dark" style="background-color: #FF8C00; border-color: #FF8C00;">
                <tr>
                    <th>Désignation</th>
                    <th class="text-center">Quantité</th>
                    <th class="text-center">Prix Unitaire</th>
                    <th class="text-end">Sous-total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="py-3 fw-bold">@item.ProductName</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-center">@item.UnitPrice.ToString("N2") $</td>
                        <td class="text-end fw-bold">@((item.UnitPrice * item.Quantity).ToString("N2")) $</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="row justify-content-end">
        <div class="col-5">
            <div class="total-box shadow-sm">
                <small class="text-uppercase fw-bold text-muted">Montant Total Payé</small>
                <h1 class="mb-0" style="color: #FF8C00;">@Model.FinalPrice.ToString("N2") $</h1>
            </div>
            <p class="mt-3 text-end">
                <strong>Mode :</strong> @Model.PaymentMethod <br>
                <strong>Date :</strong> @Model.SaleDate.ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>
    </div>

    <div class="mt-5 pt-4 text-center border-top">
        @if (!string.IsNullOrEmpty(settings.ReceiptFooterMessage))
        {
            <p class="fw-bold footer-message">@settings.ReceiptFooterMessage</p>
        }
        <p class="text-muted small">Généré par <strong>AdGestionHub</strong> le @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    </div>
</body>
</html>