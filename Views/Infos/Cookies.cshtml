@{
    ViewData["Title"] = "Gestion des Cookies";
}

<div class="container mt-5 shadow-sm p-5 bg-white rounded border-top border-warning border-5">
    <h1 class="text-orange fw-bold mb-4">🍪 @ViewData["Title"]</h1>
    <hr />
    <div class="legal-text" style="line-height: 1.8; color: #333;">
        <p>AdGestionHub utilise uniquement des cookies techniques essentiels :</p>
        <ul>
            <li><strong>Cookies de session :</strong> Pour rester connecté à votre tableau de bord.</li>
            <li><strong>Cookies de préférence :</strong> Pour mémoriser vos choix d'affichage.</li>
        </ul>
        <p><strong>Zéro Tracking :</strong> Nous n'utilisons aucun cookie publicitaire. Votre navigation reste privée.</p>
    </div>
</div>