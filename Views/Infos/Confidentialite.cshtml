@{
    ViewData["Title"] = "Politique de Confidentialité";
}

<div class="container mt-5 shadow-sm p-5 bg-white rounded border-top border-warning border-5">
    <h1 class="text-orange fw-bold mb-4">🔒 @ViewData["Title"]</h1>
    <hr />
    <div class="legal-text" style="line-height: 1.8; color: #333;">
        <h4 class="fw-bold">VOS DONNÉES SONT SACRÉES</h4>
        <p>Nous nous engageons formellement à ne <strong>JAMAIS vendre</strong> ou transmettre vos données à des tiers.</p>

        <h4 class="fw-bold mt-4">DONNÉES COLLECTÉES</h4>
        <ul>
            <li><strong>Gérant :</strong> Nom, email, nom de la boutique.</li>
            <li><strong>Clients :</strong> Nom saisi lors de la création d'un reçu.</li>
        </ul>

        <h4 class="fw-bold mt-4">SÉCURITÉ ET DROITS</h4>
        <p>Toutes les données sont chiffrées (SSL). Vous disposez d'un droit d'accès, de modification et de suppression totale de vos données à tout moment.</p>
    </div>
</div>