@model AdGestionHub.Models.DashboardViewModel

@{
    ViewData["Title"] = "Tableau de Bord";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0" style="color: #FF8C00;">📊 Tableau de Bord AdGestionHub</h2>

        <div class="d-flex flex-wrap gap-3">
           @* <a asp-controller="Reports" asp-action="GenerateDailyReport"
               class="btn btn-outline-dark fw-bold shadow-sm"
               style="border-radius: 8px; padding: 10px 20px; border: 2px solid #343a40;">
                <i class="fas fa-file-pdf"></i> Télécharger Rapport PDF
            </a>*@

            <a asp-controller="Sales" asp-action="Create"
               class="btn text-white fw-bold shadow-sm"
               style="background-color: #FF8C00; border: none; border-radius: 8px; padding: 10px 20px;">
                <i class="fas fa-plus"></i> Enregistrer une Vente
            </a>

            <a asp-controller="Expenses" asp-action="Index"
               class="btn text-white fw-bold shadow-sm"
               style="background-color: #FF8C00; border: none; border-radius: 8px; padding: 10px 20px;">
                <i class="fas fa-book"></i> Journal Dépenses
            </a>
        </div>
    </div>

    <div class="row">
        @if (User.IsInRole("Admin") || User.Identity.IsAuthenticated) // Ajusté pour visibilité
        {
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm h-100" style="background-color: #fff8f0; border: 1px solid #FF8C00; min-height: 110px;">
                    <div class="card-body">
                        <h6 class="card-title text-muted">Chiffre d'Affaires</h6>
                        <h3 class="fw-bold text-warning">@Model.TotalSales.ToString("N2") $</h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card shadow-sm h-100" style="background-color: #fdfdfd; border: 1px solid #FF8C00; min-height: 110px;">
                    <div class="card-body">
                        <h6 class="card-title text-muted">Bénéfice Net</h6>
                        <h3 class="fw-bold @(Model.TotalProfit < 0 ? "text-danger" : "text-success")">
                            @Model.TotalProfit.ToString("N2") $
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card shadow-sm h-100" style="background-color: #fff4f4; border: 1px solid #dc3545; min-height: 110px;">
                    <div class="card-body">
                        <h6 class="card-title text-muted">Dettes Clients</h6>
                        <h3 class="fw-bold text-danger">@(((decimal)(ViewBag.TotalDebts ?? 0)).ToString("N2")) $</h3>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm h-100" style="background-color: #f9f9f9; border: 1px solid #ddd; min-height: 110px;">
                <div class="card-body">
                    <h6 class="card-title text-muted">Ventes réalisées</h6>
                    <h3 class="fw-bold text-primary">@Model.TotalTransactions</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 mb-3">
            <div class="card shadow-sm h-100" style="background-color: #f9f9f9; border: 1px solid #ddd; min-height: 110px;">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-muted mb-0">Alertes Stock</h6>
                        <small class="text-muted">Produits sous le seuil critique</small>
                    </div>
                    <h3 class="fw-bold mb-0 @(Model.LowStockCount > 0 ? "text-danger" : "text-success")">@Model.LowStockCount</h3>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <div class="row">
        <div class="col-md-12">
            <h4 class="mb-3 text-muted">Dernières Ventes</h4>
            <div class="table-responsive bg-white p-3 shadow-sm rounded">
                <table class="table table-hover align-middle">
                    <thead style="background-color: #fff3e0;">
                        <tr>
                            <th>Date</th>
                            <th>Produit(s)</th>
                            <th class="text-center">Qté Totale</th>
                            <th class="text-end">Total</th>
                            <th class="text-center">Paiement</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RecentSales)
                        {
                            <tr>
                                <td>@item.SaleDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.Items != null && item.Items.Any())
                                    {
                                        @string.Join(", ", item.Items.Select(i => i.ProductName ?? "Produit inconnu"))
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Aucun détail</span>
                                    }
                                </td>
                                <td class="text-center">@(item.Items?.Sum(i => i.Quantity) ?? 0)</td>
                                <td class="fw-bold text-success text-end">@item.FinalPrice.ToString("N2") $</td>
                                <td class="text-center"><span class="badge bg-secondary">@item.PaymentMethod</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>