<!-- ==================== FILE: Views/Home/Index.cshtml ==================== -->
@model AdGestionHub.Models.DashboardViewModel

@{
    ViewData["Title"] = "Tableau de Bord";
}

<div>
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold mb-0">Dashboard</h1>
            <p class="text-muted">Vue d'ensemble de votre activité commerciale</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Sales" asp-action="Create" class="btn btn-primary-gradient">
                <i class="fas fa-plus me-2"></i> Nouvelle Vente
            </a>
            <a asp-controller="Expenses" asp-action="Create" class="btn btn-soft">
                <i class="fas fa-plus me-2"></i> Dépense
            </a>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-xl-3 animate-fade-up delay-1">
            <div class="card-dashboard">
                <div class="icon-wrapper orange">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-number">@Model.TotalSales.ToString("N0") $</div>
                <div class="stat-label">Chiffre d'affaires</div>
                <div class="mt-2 small text-success"><i class="fas fa-arrow-up me-1"></i> +12% vs mois dernier</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3 animate-fade-up delay-2">
            <div class="card-dashboard">
                <div class="icon-wrapper green">
                    <i class="fas fa-wallet"></i>
                </div>
                <div class="stat-number @(Model.TotalProfit < 0 ? "text-danger" : "text-success")">@Model.TotalProfit.ToString("N0") $</div>
                <div class="stat-label">Bénéfice Net</div>
                <div class="mt-2 small text-muted">Marge @((Model.TotalSales > 0 ? (Model.TotalProfit / Model.TotalSales * 100) : 0).ToString("F1"))%</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3 animate-fade-up delay-3">
            <div class="card-dashboard">
                <div class="icon-wrapper red">
                    <i class="fas fa-hand-holding-usd"></i>
                </div>
                <div class="stat-number text-danger">@ViewBag.TotalDebts?.ToString("N0") $</div>
                <div class="stat-label">Dettes Clients</div>
                <div class="mt-2 small text-muted">à recouvrer</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3 animate-fade-up delay-4">
            <div class="card-dashboard">
                <div class="icon-wrapper blue">
                    <i class="fas fa-boxes"></i>
                </div>
                <div class="stat-number">@Model.LowStockCount</div>
                <div class="stat-label">Alertes Stock</div>
                <div class="mt-2 small @(Model.LowStockCount > 0 ? "text-danger" : "text-success")">
                    @(Model.LowStockCount > 0 ? $"{Model.LowStockCount} produits en rupture imminente" : "Tous les stocks sont sains")
                </div>
            </div>
        </div>
    </div>

    <!-- Dernières Ventes -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 py-3 px-4">
            <h5 class="fw-bold mb-0"><i class="fas fa-clock me-2"></i> Dernières Ventes</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Produit(s)</th>
                            <th class="text-center">Quantité</th>
                            <th class="text-end">Total</th>
                            <th class="text-center">Paiement</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RecentSales)
                        {
                            <tr>
                                <td>@item.SaleDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.Items != null && item.Items.Any())
                                    {
                                        @string.Join(", ", item.Items.Select(i => i.ProductName ?? "Produit inconnu"))
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Aucun détail</span>
                                    }
                                </td>
                                <td class="text-center">@(item.Items?.Sum(i => i.Quantity) ?? 0)</td>
                                <td class="text-end fw-bold text-success">@item.FinalPrice.ToString("N2") $</td>
                                <td class="text-center"><span class="badge-status info">@item.PaymentMethod</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>