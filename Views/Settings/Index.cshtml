@model AdGestionHub.Models.StoreSettings

@{
    ViewData["Title"] = "Paramètres du Magasin";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header text-white" style="background-color: #FF8C00;">
            <h3 class="mb-0">⚙️ Configuration du Profil Magasin</h3>
        </div>
        <div class="card-body p-4">
            <p class="text-muted">Ces informations apparaîtront sur vos factures et reçus de vente.</p>
            <hr />

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="Index" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="BoutiqueId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="StoreName" class="form-label fw-bold">Nom de l'Enseigne</label>
                        <input asp-for="StoreName" class="form-control border-warning" placeholder="Ex: AdGestion Boutique" />
                        <span asp-validation-for="StoreName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-bold">Téléphone de contact</label>
                        <input asp-for="PhoneNumber" class="form-control border-warning" placeholder="Ex: +243 81 00 00 000" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Address" class="form-label fw-bold">Adresse complète</label>
                        <input asp-for="Address" class="form-control border-warning" placeholder="Ex: Kinshasa, Gombe..." />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Email" class="form-label fw-bold">Email de contact</label>
                        <input asp-for="Email" class="form-control border-warning" type="email" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="ReceiptFooterMessage" class="form-label fw-bold">Message de bas de facture</label>
                        <textarea asp-for="ReceiptFooterMessage" class="form-control border-warning" rows="2"></textarea>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn text-white px-5 shadow-sm" style="background-color: #FF8C00;">
                        💾 Enregistrer les modifications
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}