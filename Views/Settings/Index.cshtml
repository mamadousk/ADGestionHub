<!-- ==================== FILE: Views/Settings/Index.cshtml ==================== -->
@model AdGestionHub.Models.StoreSettings

@{
    ViewData["Title"] = "Paramètres du Magasin";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white border-0 py-4 px-4">
                <h3 class="fw-bold mb-0"><i class="fas fa-store text-primary me-2"></i>Configuration du profil</h3>
                <p class="text-muted small">Ces informations apparaîtront sur vos factures et reçus de vente.</p>
            </div>
            <div class="card-body p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success border-0 shadow-sm rounded-4 d-flex align-items-center" role="alert">
                        <i class="fas fa-check-circle me-3 fa-lg"></i>
                        <div>@TempData["Success"]</div>
                    </div>
                }

                <form asp-action="Index" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="BoutiqueId" />

                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="StoreName" class="form-label fw-semibold">Nom de l'enseigne</label>
                            <input asp-for="StoreName" class="form-control form-control-modern" placeholder="Ex: AdGestion Boutique" />
                            <span asp-validation-for="StoreName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Téléphone</label>
                            <input asp-for="PhoneNumber" class="form-control form-control-modern" placeholder="+243 81 00 00 000" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email de contact</label>
                            <input asp-for="Email" class="form-control form-control-modern" type="email" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Address" class="form-label fw-semibold">Adresse complète</label>
                            <input asp-for="Address" class="form-control form-control-modern" placeholder="Kinshasa, Gombe..." />
                        </div>

                        <div class="col-12">
                            <label asp-for="ReceiptFooterMessage" class="form-label fw-semibold">Message de bas de facture</label>
                            <textarea asp-for="ReceiptFooterMessage" class="form-control form-control-modern" rows="2" placeholder="Merci de votre visite !"></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary-gradient px-5">
                            <i class="fas fa-save me-2"></i>Enregistrer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}