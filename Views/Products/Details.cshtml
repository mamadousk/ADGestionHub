@using AdGestionHub.Models
@model Product

@{
    ViewData["Title"] = $"Détails - {Model.Name}";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white border-0 py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-wrapper orange" style="width: 56px; height: 56px; border-radius: 16px; background: #fff3e0; display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-box fa-2x" style="color: #FF8C00;"></i>
                    </div>
                    <div>
                        <h1 class="display-6 fw-bold mb-0">@Model.Name</h1>
                        <p class="text-muted small">ID Produit : #@Model.Id</p>
                    </div>
                </div>
            </div>
            <div class="card-body p-4 p-lg-5">
                <div class="row g-4">
                    <div class="col-md-6">
                        <h5 class="fw-bold text-muted mb-3">📊 Informations générales</h5>
                        <dl class="row">
                            <dt class="col-sm-5 fw-bold text-dark">Nom :</dt>
                            <dd class="col-sm-7">@Model.Name</dd>

                            <dt class="col-sm-5 fw-bold text-dark">En stock :</dt>
                            <dd class="col-sm-7">
                                @{
                                    var stockClass = Model.StockQuantity <= Model.LowStockThreshold ? "badge-status danger" : "badge-status success";
                                }
                                <span class="@stockClass">@Model.StockQuantity unités</span>
                            </dd>

                            <dt class="col-sm-5 fw-bold text-dark">Seuil d'alerte :</dt>
                            <dd class="col-sm-7">
                                @if (Model.StockAlertThreshold > 0)
                                {
                                    <span>@Model.StockAlertThreshold</span>
                                }
                                else
                                {
                                    <span class="text-muted">Non défini</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <h5 class="fw-bold text-muted mb-3">💰 Analyse financière</h5>
                        <dl class="row">
                            <dt class="col-sm-5 fw-bold text-dark">Prix d'achat :</dt>
                            <dd class="col-sm-7">@Model.PurchasePrice.ToString("N2") $</dd>

                            <dt class="col-sm-5 fw-bold text-dark">Prix de vente :</dt>
                            <dd class="col-sm-7 fw-bold h5" style="color: #FF8C00;">@Model.SalePrice.ToString("N2") $</dd>

                            <dt class="col-sm-5 fw-bold text-dark">Marge estimée :</dt>
                            <dd class="col-sm-7 text-success fw-bold">
                                @((Model.SalePrice - Model.PurchasePrice).ToString("N2")) $
                            </dd>
                        </dl>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-soft"><i class="fas fa-arrow-left me-2"></i>Retour</a>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-gradient">
                            <i class="fas fa-edit me-2"></i>Modifier
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>