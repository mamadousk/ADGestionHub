@using AdGestionHub.Models
@using Microsoft.AspNetCore.Identity
@model IEnumerable<Product>

<div>
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-0">📦 Gestion du Stock</h1>
            <p class="text-muted">Liste de vos produits et alertes de réapprovisionnement</p>
        </div>
        <a asp-action="Create" class="btn btn-primary-gradient">
            <i class="fas fa-plus me-2"></i> Nouveau Produit
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th>Nom du produit</th>
                            @if (User.IsInRole("Admin"))
                            {
                                <th>Prix d'achat</th>
                            }
                            <th>Prix de vente</th>
                            <th class="text-center">Stock</th>
                            <th class="text-center">Statut</th>
                            <th>Code-barres</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Name</td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td>@item.PurchasePrice.ToString("N2") $</td>
                                }
                                <td>@item.SalePrice.ToString("N2") $</td>
                                <td class="text-center">@item.StockQuantity</td>
                                <td class="text-center">
                                    @if (item.StockQuantity <= 0)
                                    {
                                        <span class="badge-status danger">Rupture</span>
                                    }
                                    else if (item.StockQuantity <= item.LowStockThreshold)
                                    {
                                        <span class="badge-status warning">Stock bas</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status success">Disponible</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Barcode))
                                    {
                                        <span class="small text-muted">@item.Barcode</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Non défini</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-soft" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-soft" title="Détails">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="PrintBarcode" asp-route-id="@item.Id" class="btn btn-sm btn-soft" title="Imprimer l'étiquette">
                                            <i class="fas fa-tag"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-soft text-danger" title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>