@using AdGestionHub.Models
@model Product

@{
    ViewData["Title"] = "Modifier le Produit";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header text-white py-3" style="background-color: #FF8C00 !important; border: none;">
            <h4 class="mb-0"><i class="fas fa-edit me-2"></i> Modification du Produit</h4>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @* ID masqué pour la mise à jour *@
                <input type="hidden" asp-for="Id" />

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Name" class="form-label fw-bold">Désignation du produit</label>
                        <input asp-for="Name" class="form-control border-warning" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PurchasePrice" class="form-label fw-bold">Prix d'Achat</label>
                        <div class="input-group">
                            <input asp-for="PurchasePrice" class="form-control" />
                            <span class="input-group-text">USD</span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SalePrice" class="form-label fw-bold">Prix de Vente</label>
                        <div class="input-group">
                            <input asp-for="SalePrice" class="form-control" />
                            <span class="input-group-text">USD</span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="StockQuantity" class="form-label fw-bold">Quantité disponible</label>
                        <input asp-for="StockQuantity" class="form-control" type="number" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="StockAlertThreshold" class="form-label fw-bold text-orange" style="color: #FF8C00;">Seuil d'alerte stock</label>
                        <input asp-for="StockAlertThreshold" class="form-control border-orange" type="number" />
                        <small class="text-muted">Alerte active à partir de @Model.StockAlertThreshold unités.</small>
                    </div>

                    <div class="col-12">
                        <label asp-for="Variations" class="form-label fw-bold">Variations (Pointures/Tailles)</label>
                        <textarea asp-for="Variations" class="form-control" rows="2"></textarea>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-light border">Annuler</a>
                    <button type="submit" class="btn text-white shadow-sm" style="background-color: #FF8C00; min-width: 150px;">
                        Mettre à jour
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}