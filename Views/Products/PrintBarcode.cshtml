@using AdGestionHub.Models
@model Product

@{
    Layout = null;
    var storeName = ViewBag.StoreName ?? "Ma Boutique";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Étiquette - @Model.Name</title>
    <style>
            body {
                font-family: 'Segoe UI', sans-serif;
                display: flex;
                justify-content: center;
                align-items: center;
                height: 100vh;
                margin: 0;
                background: #f5f5f5;
            }

            .label {
                background: white;
                padding: 30px 20px;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                text-align: center;
                width: 350px;
                border: 1px solid #ddd;
            }

            .store-name {
                font-size: 18px;
                font-weight: 700;
                color: #FF8C00;
                margin-bottom: 8px;
            }

            .product-name {
                font-size: 22px;
                font-weight: 600;
                margin: 10px 0;
            }

            .price {
                font-size: 28px;
                font-weight: 700;
                color: #1a1a1a;
                margin: 10px 0;
            }

            .barcode {
                margin: 15px 0;
                padding: 10px;
                background: #fafafa;
                border-radius: 8px;
                font-family: 'Courier New', monospace;
                font-size: 24px;
                letter-spacing: 4px;
                color: #333;
            }

            .footer {
                margin-top: 10px;
                font-size: 11px;
                color: #999;
            }
    </style>
</head>
<body>
    <div class="label">
        <div class="store-name">@storeName</div>
        <div class="product-name">@Model.Name</div>
        <div class="price">@Model.SalePrice.ToString("N0") $</div>
        <div class="barcode">* @Model.Barcode *</div>
        <div class="footer">Code interne • @DateTime.Now.ToString("dd/MM/yyyy")</div>
    </div>
</body>
</html>