@model AdGestionHub.Models.ReportViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 12px;
        }

        .header-report {
            border-bottom: 2px solid #FF8C00;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .text-orange {
            color: #FF8C00;
        }

        .table thead {
            background-color: #f8f9fa;
        }
    </style>
</head>
<body class="p-4">
    <div class="header-report d-flex justify-content-between">
        <div>
            <h2 class="text-orange fw-bold">@ViewData["StoreName"]</h2>
            <p class="text-muted">Logiciel AdGestionHub - Rapport Journalier</p>
        </div>
        <div class="text-end">
            <h5>Date: @ViewData["ReportDate"]</h5>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-6">
            <div class="card p-3 border-dark">
                <h6>Total Ventes</h6>
                <h4 class="text-success">@Model.TotalSales.ToString("N2") $</h4>
            </div>
        </div>
        <div class="col-6">
            <div class="card p-3 border-dark">
                <h6>Total Dépenses</h6>
                <h4 class="text-danger">@Model.TotalExpenses.ToString("N2") $</h4>
            </div>
        </div>
    </div>

    <h4>Détails des Ventes</h4>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Heure</th>
                <th>Produits</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sale in Model.Sales)
            {
                <tr>
                    <td>@sale.SaleDate.ToString("HH:mm")</td>
                    <td>@string.Join(", ", sale.Items.Select(i => i.ProductName))</td>
                    <td>@sale.FinalPrice.ToString("N2") $</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-5 text-center text-muted">
        <small>&copy; 2026 AdGestionHub - Document officiel généré par Adhil Digital Solutions</small>
    </div>
</body>
</html>