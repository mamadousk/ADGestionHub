@using AdGestionHub.Models
@model IEnumerable<GlobalNotification>

@{
    ViewData["Title"] = "Historique des notifications";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold mb-0"><i class="fas fa-history me-2"></i>Historique des notifications</h1>
            <p class="text-muted">Liste de toutes les annonces globales envoyées</p>
        </div>
        <a asp-action="Index" class="btn btn-soft"><i class="fas fa-arrow-left me-2"></i>Retour</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th>Expiration</th>
                            <th>Message</th>
                            <th>Importance</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-light text-dark">@item.ExpiryDate.ToString("dd/MM/yyyy HH:mm")</span>
                                    </td>
                                    <td class="fw-semibold">@item.Message</td>
                                    <td>
                                        @if (item.IsCritical)
                                        {
                                            <span class="badge-status danger"><i class="fas fa-exclamation-circle me-1"></i> Critique</span>
                                        }
                                        else
                                        {
                                            <span class="badge-status info"><i class="fas fa-info-circle me-1"></i> Information</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <form asp-action="DeleteNotification" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Supprimer définitivement cette annonce ?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-soft text-danger">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center py-4 text-muted">Aucune notification enregistrée.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>