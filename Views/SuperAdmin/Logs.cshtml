@using System.Text.Encodings.Web
@model IEnumerable<AdGestionHub.Models.ErrorLog>

@{
    ViewData["Title"] = "Journal des Erreurs";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold mb-0"><i class="fas fa-exclamation-triangle text-danger me-2"></i>Journal des Erreurs</h1>
            <p class="text-muted">Suivi des exceptions et incidents système</p>
        </div>
        <span class="badge bg-dark rounded-pill px-3 py-2 fs-6">Total : @Model.Count()</span>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Utilisateur</th>
                            <th>Emplacement</th>
                            <th>Message</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            var severity = log.Message?.Contains("Exception", StringComparison.OrdinalIgnoreCase) == true ? "danger" : "warning";
                            <tr>
                                <td><span class="badge bg-light text-dark">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></td>
                                <td><span class="badge-status info">@(log.UserEmail ?? "Anonyme")</span></td>
                                <td><small class="text-muted">@log.ControllerName / @log.ActionName</small></td>
                                <td>
                                    <span class="badge-status @(severity == "danger" ? "danger" : "warning")">
                                        @log.Message
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-soft" onclick="showDetails('@Html.Raw(JavaScriptEncoder.Default.Encode(log.StackTrace ?? "Aucune trace"))')">
                                        <i class="fas fa-eye"></i> Détails
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showDetails(stackTrace) {
            alert("Détails de l'erreur :\n\n" + stackTrace);
        }
    </script>
}