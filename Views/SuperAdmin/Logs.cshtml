@using System.Text.Encodings.Web
@model IEnumerable<AdGestionHub.Models.ErrorLog>

@{
    ViewData["Title"] = "Logs Système";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-exclamation-triangle text-danger"></i> Journal des Erreurs</h2>
        <span class="badge bg-dark">Total : @Model.Count()</span>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Date</th>
                        <th>Utilisateur</th>
                        <th>Emplacement</th>
                        <th>Message</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="small">@log.CreatedAt.ToString("dd/MM HH:mm")</td>
                            <td><span class="badge bg-info text-dark">@log.UserEmail</span></td>
                            <td>
                                <small class="text-muted">@log.ControllerName/@log.ActionName</small>
                            </td>
                            <td class="text-truncate" style="max-width: 300px;">
                                <strong class="text-danger">@log.Message</strong>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="alert('@Html.Raw(JavaScriptEncoder.Default.Encode(log.StackTrace ?? "Pas de trace"))')">
                                    <i class="fas fa-eye"></i> Détails
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>