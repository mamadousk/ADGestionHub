@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Données personnelles";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="fw-bold">@ViewData["Title"]</h3>
<p class="text-muted">Gérez vos données personnelles stockées sur la plateforme.</p>

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-3">
            <p class="mb-2">Votre compte contient des données personnelles que vous nous avez fournies. Cette page vous permet de télécharger ou de supprimer ces données.</p>
            <p class="text-danger fw-bold">
                <i class="fas fa-exclamation-triangle me-2"></i>
                La suppression de ces données entraînera la fermeture définitive de votre compte.
            </p>
        </div>

        <div class="d-flex gap-3">
            <form id="download-data" asp-page="DownloadPersonalData" method="post">
                <button class="btn btn-primary-gradient" type="submit">
                    <i class="fas fa-download me-2"></i> Télécharger mes données
                </button>
            </form>
            <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger">
                <i class="fas fa-trash me-2"></i> Supprimer mon compte
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}