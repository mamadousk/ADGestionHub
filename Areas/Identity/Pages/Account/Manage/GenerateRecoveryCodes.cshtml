@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Générer des codes de récupération (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<h3 class="fw-bold">@ViewData["Title"]</h3>
<p class="text-muted">Générez de nouveaux codes de récupération pour sécuriser votre compte.</p>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="alert alert-warning border-0 shadow-sm rounded-4">
    <i class="fas fa-exclamation-triangle me-2"></i>
    <strong>Conservez ces codes dans un endroit sûr.</strong>
    <p class="mb-0">Si vous perdez votre appareil et que vous n'avez pas ces codes, vous perdrez l'accès à votre compte.</p>
    <p class="mb-0">La génération de nouveaux codes ne modifie pas les clés de l'application d'authentification. Pour changer la clé, <a asp-page="./ResetAuthenticator" class="fw-bold text-decoration-none">réinitialisez vos clés d'authentification</a>.</p>
</div>

<div>
    <form method="post">
        <button class="btn btn-danger" type="submit">
            <i class="fas fa-sync me-2"></i> Générer des codes de récupération
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}