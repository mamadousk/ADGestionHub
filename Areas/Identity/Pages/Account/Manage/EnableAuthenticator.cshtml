@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configurer l'application d'authentification";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<h3 class="fw-bold">@ViewData["Title"]</h3>
<p class="text-muted">Scannez le QR code avec votre application d'authentification (ex: Google Authenticator).</p>

<partial name="_StatusMessage" for="StatusMessage" />

<div>
    <ol class="list-group list-group-numbered mb-4">
        <li class="list-group-item border-0 bg-transparent">
            <p>Téléchargez une application d'authentification comme :</p>
            <ul>
                <li><a href="https://go.microsoft.com/fwlink/?Linkid=825072">Microsoft Authenticator</a> (Android / iOS)</li>
                <li><a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2">Google Authenticator</a> (Android)</li>
                <li><a href="https://itunes.apple.com/us/app/google-authenticator/id388497605">Google Authenticator</a> (iOS)</li>
            </ul>
        </li>
        <li class="list-group-item border-0 bg-transparent">
            <p>Scannez ce QR code avec votre application :</p>
            <div class="bg-light p-3 rounded-4 d-inline-block text-center" style="min-width: 200px;">
                <div id="qrCode"></div>
                <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
                <p class="mt-2 small text-muted">Clé : <kbd>@Model.SharedKey</kbd></p>
            </div>
        </li>
        <li class="list-group-item border-0 bg-transparent">
            <p>Entrez le code à 6 chiffres généré par l'application :</p>
            <div class="row">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div class="mb-3">
                            <label asp-for="Input.Code" class="form-label fw-semibold">Code de vérification</label>
                            <input asp-for="Input.Code" class="form-control form-control-modern" placeholder="123456" />
                            <span asp-validation-for="Input.Code" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary-gradient">
                            <i class="fas fa-check-circle me-2"></i> Vérifier
                        </button>
                        <div asp-validation-summary="ModelOnly" class="text-danger mt-3" role="alert"></div>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}