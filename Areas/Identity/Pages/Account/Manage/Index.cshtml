@page
@model IndexModel
@{
    ViewData["Title"] = "Mon Profil";
}

<h3 class="fw-bold">@ViewData["Title"]</h3>
<p class="text-muted">Mettez à jour vos informations personnelles.</p>

<partial name="_StatusMessage" for="StatusMessage" />

<form id="profile-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="mb-3">
        <label asp-for="Username" class="form-label fw-semibold">Email / Identifiant</label>
        <input asp-for="Username" class="form-control form-control-modern" disabled />
    </div>

    <div class="mb-3">
        <label asp-for="Input.PhoneNumber" class="form-label fw-semibold">Numéro de téléphone</label>
        <input asp-for="Input.PhoneNumber" class="form-control form-control-modern" placeholder="+243 810000000" />
        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
    </div>

    <button id="update-profile-button" type="submit" class="btn btn-primary-gradient">
        <i class="fas fa-save me-2"></i> Enregistrer
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}