@page
@model LoginModel
@{
    ViewData["Title"] = "Connexion";
    Layout = "_Layout";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height:80vh;">
    <div class="card shadow-lg border-0 rounded-4" style="max-width: 420px; width:100%;">
        <div class="card-body p-5">
            <h2 class="fw-bold text-center mb-4" style="color:#FF8C00;">Connexion</h2>
            <p class="text-muted text-center mb-4">Accédez à votre espace sécurisé AdGestionHub</p>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-bold">E-mail</label>
                    <input asp-for="Input.Email" class="form-control rounded-pill" autocomplete="username" placeholder="exemple@domaine.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-bold">Mot de passe</label>
                    <input asp-for="Input.Password" class="form-control rounded-pill" type="password" autocomplete="current-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label text-muted">Se souvenir de moi</label>
                </div>

                <button id="login-submit" type="submit" class="btn btn-lg w-100 text-white rounded-pill shadow-sm" style="background-color:#FF8C00;">
                    🚀 Se connecter
                </button>
            </form>

            <div class="text-center mt-4">
                <a asp-page="./ForgotPassword" class="text-decoration-none text-muted small">Mot de passe oublié ?</a><br />
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold" style="color:#FF8C00;">Créer un compte</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}