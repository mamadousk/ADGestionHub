@page
@model RegisterModel
@{
    ViewData["Title"] = "Créer un compte";
    Layout = "_Layout";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height:80vh;">
    <div class="card shadow-lg border-0 rounded-4" style="max-width: 480px; width:100%;">
        <div class="card-body p-5">
            <h2 class="fw-bold text-center mb-4" style="color:#FF8C00;">Créer un compte</h2>
            <p class="text-muted text-center mb-4">Propulsez votre business avec AdGestionHub</p>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.StoreName" class="form-label fw-bold">Nom de votre Boutique</label>
                    <input asp-for="Input.StoreName" class="form-control rounded-pill" placeholder="Ex: Ma Super Boutique" />
                    <span asp-validation-for="Input.StoreName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-bold">E-mail</label>
                    <input asp-for="Input.Email" class="form-control rounded-pill" autocomplete="username" placeholder="exemple@domaine.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-bold">Mot de passe</label>
                    <input asp-for="Input.Password" class="form-control rounded-pill" type="password" autocomplete="new-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-bold">Confirmer</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control rounded-pill" type="password" autocomplete="new-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn btn-lg w-100 text-white rounded-pill shadow-sm" style="background-color:#FF8C00;">
                    ✨ Créer mon compte
                </button>
            </form>

            <div class="text-center mt-4">
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none text-muted">Déjà inscrit ? Se connecter</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}