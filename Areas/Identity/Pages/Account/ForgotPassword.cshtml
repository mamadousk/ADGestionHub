@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Mot de passe oublié";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="card shadow-lg border-0 rounded-4" style="max-width: 440px; width:100%;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div class="icon-wrapper orange mx-auto" style="width: 64px; height: 64px; border-radius: 50%; background: #fff3e0; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
                    <i class="fas fa-key fa-2x" style="color: #FF8C00;"></i>
                </div>
                <h2 class="fw-bold" style="color: #FF8C00;">Mot de passe oublié ?</h2>
                <p class="text-muted small">Entrez votre email pour recevoir un lien de réinitialisation.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-semibold">Adresse email</label>
                    <input asp-for="Input.Email" class="form-control form-control-modern" autocomplete="username" placeholder="exemple@domaine.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary-gradient w-100 py-3 rounded-pill shadow-sm">
                    <i class="fas fa-paper-plane me-2"></i> Envoyer le lien
                </button>
            </form>

            <div class="text-center mt-4">
                <a asp-page="./Login" class="text-decoration-none small" style="color: #FF8C00;">
                    <i class="fas fa-arrow-left me-1"></i> Retour à la connexion
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}